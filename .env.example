# Passwortmanager-Äquivalent zu config.js:
# Diese Werte gehören in Vercel ENV oder in eine lokale .env-Datei,
# NICHT in eine öffentliche window.CONFIG im Browser.

SUPABASE_DB_URL=postgresql://USER:PASSWORD@HOST:6543/postgres?sslmode=require
VAULT_ENCRYPTION_KEY=replace-with-a-long-random-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password
ADMIN_DISPLAY_NAME=Frederik Admin

# Optionaler Alias, falls du lieber DATABASE_URL benutzen willst
DATABASE_URL=
